{
  "$description": "Figma “Typography Primitives.Mode 1” — font sizes and line heights (px, except leading-none = unitless 1). Fixed typo: Line-hieght → lineHeight. Aligns with --text-* and --leading-* in theme.css.",
  "typographyPrimitives": {
    "fontSize": {
      "xxs": { "$type": "number", "$value": 9 },
      "xs": { "$type": "number", "$value": 12 },
      "sm": { "$type": "number", "$value": 14 },
      "base": { "$type": "number", "$value": 16 },
      "lg": { "$type": "number", "$value": 18 },
      "xl": { "$type": "number", "$value": 20 },
      "2xl": { "$type": "number", "$value": 24 },
      "3xl": { "$type": "number", "$value": 32 },
      "4xl": { "$type": "number", "$value": 40 },
      "5xl": { "$type": "number", "$value": 48 },
      "6xl": { "$type": "number", "$value": 56 },
      "7xl": { "$type": "number", "$value": 64 },
      "8xl": { "$type": "number", "$value": 72 },
      "9xl": { "$type": "number", "$value": 80 }
    },
    "lineHeight": {
      "leading-none": { "$type": "number", "$value": 1 },
      "leading-3": { "$type": "number", "$value": 14 },
      "leading-4": { "$type": "number", "$value": 16 },
      "leading-5": { "$type": "number", "$value": 20 },
      "leading-ct": { "$type": "number", "$value": 22 },
      "leading-6": { "$type": "number", "$value": 24 },
      "leading-7": { "$type": "number", "$value": 28 },
      "leading-8": { "$type": "number", "$value": 30 },
      "leading-9": { "$type": "number", "$value": 36 },
      "leading-10": { "$type": "number", "$value": 40 },
      "leading-11": { "$type": "number", "$value": 48 },
      "leading-12": { "$type": "number", "$value": 56 },
      "leading-13": { "$type": "number", "$value": 60 },
      "leading-14": { "$type": "number", "$value": 72 },
      "leading-15": { "$type": "number", "$value": 84 }
    }
  }
}
