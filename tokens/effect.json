{
  "$description": "Figma “Effect.Mode 1” — backdrop blur radii and drop shadows. Renamed: Blackground blur → backgroundBlur; Spread (not Sqread). Each drop shadow includes `boxShadowCss` matching src/styles/theme.css @theme --shadow-* where applicable.",
  "effectMode1": {
    "backgroundBlur": {
      "blur-xs": { "$type": "number", "$value": 4 },
      "blur-sm": { "$type": "number", "$value": 8 },
      "blur-md": { "$type": "number", "$value": 12 },
      "blur-lg": { "$type": "number", "$value": 16 },
      "blur-xl": { "$type": "number", "$value": 24 },
      "blur-2xl": { "$type": "number", "$value": 40 },
      "blur-3xl": { "$type": "number", "$value": 64 }
    },
    "dropShadow": {
      "2xs": {
        "$type": "string",
        "$value": "0 1px 0 0 rgba(0, 0, 0, 0.05)",
        "$description": "theme --shadow-2xs"
      },
      "xs": {
        "$type": "string",
        "$value": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
        "$description": "theme --shadow-xs"
      },
      "sm": {
        "$type": "string",
        "$value": "0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1)",
        "$description": "theme --shadow-sm"
      },
      "default": {
        "$type": "string",
        "$value": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)",
        "$description": "theme --shadow-md (Figma name: default)"
      },
      "md": {
        "$type": "string",
        "$value": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)",
        "$description": "Figma Drop Shadow / md. theme.css --shadow-lg uses larger blur (Tailwind); align Figma or CSS intentionally."
      },
      "lg": {
        "$type": "string",
        "$value": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1)",
        "$description": "Figma Drop Shadow / lg. Repo theme --shadow-lg uses 10px/25px and 4px/10px offsets — update one side to align."
      },
      "2xl": {
        "$type": "string",
        "$value": "0 25px 50px -12px rgba(0, 0, 0, 0.25)",
        "$description": "theme --shadow-2xl"
      },
      "inner": {
        "$type": "string",
        "$value": "inset 0 2px 4px 0 rgba(0, 0, 0, 0.05)",
        "$description": "Figma Inner — not wired in theme.css yet"
      }
    }
  }
}
