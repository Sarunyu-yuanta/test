{
  "$description": "Figma collection “Size.Mode 1” — spacing, radius, stroke, icon. Numeric $values are in px for web (use with px suffix in CSS). Aligns with src/styles/theme.css @theme spacing/radius.",
  "sizeMode1": {
    "spacing": {
      "0": { "$type": "number", "$value": 0 },
      "0_5": { "$type": "number", "$value": 2 },
      "1": { "$type": "number", "$value": 4 },
      "1_5": { "$type": "number", "$value": 6 },
      "2": { "$type": "number", "$value": 8 },
      "2_5": { "$type": "number", "$value": 10 },
      "3": { "$type": "number", "$value": 12 },
      "3_5": { "$type": "number", "$value": 14 },
      "4": { "$type": "number", "$value": 16 },
      "5": { "$type": "number", "$value": 20 },
      "6": { "$type": "number", "$value": 24 },
      "7": { "$type": "number", "$value": 28 },
      "8": { "$type": "number", "$value": 32 },
      "9": { "$type": "number", "$value": 36 },
      "10": { "$type": "number", "$value": 40 },
      "11": { "$type": "number", "$value": 44 },
      "12": { "$type": "number", "$value": 48 },
      "13": { "$type": "number", "$value": 56 },
      "16": { "$type": "number", "$value": 64 },
      "20": { "$type": "number", "$value": 80 }
    },
    "radius": {
      "none": { "$type": "number", "$value": 0 },
      "sm": { "$type": "number", "$value": 2 },
      "default": { "$type": "number", "$value": 4, "$description": "Maps to --radius in theme" },
      "md": { "$type": "number", "$value": 6 },
      "lg": { "$type": "number", "$value": 8 },
      "xl": { "$type": "number", "$value": 12 },
      "2xl": { "$type": "number", "$value": 16 },
      "3xl": { "$type": "number", "$value": 24 },
      "full": { "$type": "number", "$value": 999, "$description": "Use 999px or full in CSS for pill" }
    },
    "stroke": {
      "border": { "$type": "number", "$value": 1 }
    },
    "icon": {
      "small": { "$type": "number", "$value": 14 },
      "medium": { "$type": "number", "$value": 16 },
      "large": { "$type": "number", "$value": 20 }
    }
  }
}
